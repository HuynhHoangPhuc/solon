{
  "description": "Solon hooks: lifecycle management, access control, context awareness",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run.sh hooks/session-init.ts" }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run.sh hooks/subagent-init.ts" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run.sh hooks/team-context-inject.ts" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "Plan",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run.sh hooks/cook-after-plan-reminder.ts" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run.sh hooks/dev-rules-reminder.ts" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run.sh hooks/usage-context-awareness.ts", "timeout": 30 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run.sh hooks/descriptive-name.ts" }
        ]
      },
      {
        "matcher": "Bash|Glob|Grep|Read|Edit|Write",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run.sh hooks/scout-block.ts" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run.sh hooks/privacy-block.ts" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run.sh hooks/post-edit-simplify-reminder.ts" }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run.sh hooks/usage-context-awareness.ts", "timeout": 10 }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run.sh notifications/notify.ts", "async": true }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run.sh hooks/task-completed-handler.ts" }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run.sh hooks/teammate-idle-handler.ts" }
        ]
      }
    ]
  }
}
