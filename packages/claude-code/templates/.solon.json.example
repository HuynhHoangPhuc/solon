{
  "$schema": "https://solon.dev/schemas/solon-config.json",
  "version": "1.0.0",
  "session": {
    "name": "my-project",
    "env": "SOLON_SESSION"
  },
  "reports": {
    "path": "./plans/reports",
    "env": "SOLON_REPORTS_PATH"
  },
  "skills": {
    "venv": "~/.solon/venv",
    "categories": {
      "core": true,
      "utility": true,
      "optional": {
        "frontend": false,
        "backend": false,
        "mobile": false,
        "ai-tools": false,
        "devops": false,
        "media": false
      }
    }
  },
  "agents": {
    "defaultModel": "sonnet",
    "memory": true
  },
  "mcp": {
    "solon_read": {
      "enabled": true,
      "description": "Hashline-annotated file reads for precise line referencing"
    }
  }
}
